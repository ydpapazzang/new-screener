# 텔레그램 봇 설정
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeEFFggHH...
TELEGRAM_CHAT_ID=1234567890

# 일일 리포트 크론 기본값 (vercel.json 크론이 호출할 때 사용)
DAILY_EXCHANGE=upbit
DAILY_STRATEGY=1
DAILY_THRESHOLD=3

# Vercel Cron 보안 시크릿 (vercel.com 대시보드 Environment Variables에 등록)
# Vercel이 크론 호출 시 Authorization: Bearer {CRON_SECRET} 헤더를 자동 첨부
CRON_SECRET=your_random_secret_here
